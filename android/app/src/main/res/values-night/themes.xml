<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Night: dark status bar tint + light status icons (not light-status-bar mode). -->
    <style name="Theme.BarcodeScanner" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/app_accent</item>
        <item name="colorPrimaryDark">@color/app_accent</item>
        <item name="colorAccent">@color/app_accent</item>
        <item name="colorOnPrimary">@color/app_text_on_button</item>
        <item name="colorSurface">@color/app_surface_input</item>
        <item name="colorOnSurface">@color/app_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/app_text_secondary</item>
        <item name="colorError">@color/app_error</item>
        <item name="colorOnError">@color/app_text_on_button</item>
        <item name="android:statusBarColor">@color/app_status_bar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/app_bg_main</item>
        <item name="android:windowBackground">@color/app_bg_main</item>
        <item name="colorControlNormal">@color/app_icon_emphasis</item>
        <item name="colorControlActivated">@color/app_accent</item>
        <item name="android:textColorPrimary">@color/app_text_primary</item>
        <item name="android:textColorSecondary">@color/app_text_secondary</item>
        <item name="textInputStyle">@style/Widget.Redacted.TextInputLayout.OutlinedBox</item>
        <item name="materialButtonStyle">@style/Widget.Redacted.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.Redacted.Button.Outlined</item>
        <item name="switchStyle">@style/Widget.Redacted.Switch</item>
        <item name="android:spinnerStyle">@style/Widget.Redacted.Spinner</item>
    </style>
</resources>
