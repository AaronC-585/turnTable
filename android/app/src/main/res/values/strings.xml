    <string name="transmission_section_title">Transmission RPC</string>
    <string name="transmission_settings_help">Optional. Send torrents to Transmission via JSON-RPC (same protocol as transmission-daemon). Default port is often 9091. Enter http://host:9091 — this app appends /transmission/rpc. If RPC auth is enabled in settings.json, set username and password. Reference: github.com/transmission/transmission</string>
