    <string name="about_version_fmt">Version %1$s</string>
    <string name="about_body"><![CDATA[turnTable is a native 1D barcode scanner for Android and iOS with a shared C++ (ZXing) core. It supports configurable music metadata lookups and optional Redacted tracker integration.<br/><br/>Open source. See the <a href="https://github.com/AaronC-585/turnTable">project README and CHANGELOG</a> in the repository for details.]]></string>
    <string name="about_logo_content_description">turnTable logo</string>
    <string name="donation_title">Donate</string>
