<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BarcodeScanner" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#3a7bd5</item>
        <item name="android:statusBarColor">#1a1a1a</item>
        <item name="android:navigationBarColor">#1a1a1a</item>
        <item name="android:windowBackground">#1a1a1a</item>
    </style>

    <style name="HomeActionColumn">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:paddingHorizontal">6dp</item>
    </style>

    <style name="HomeIconActionButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">56dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="backgroundTint">@color/home_card_bg</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="iconSize">28dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="iconPadding">0dp</item>
    </style>

    <style name="HomeActionLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/home_text_muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:maxLines">1</item>
    </style>
</resources>
