<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BarcodeScanner" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/app_accent</item>
        <item name="android:statusBarColor">@color/app_bg_main</item>
        <item name="android:navigationBarColor">@color/app_bg_main</item>
        <item name="android:windowBackground">@color/app_bg_main</item>
    </style>

    <style name="HomeActionColumn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:paddingHorizontal">2dp</item>
    </style>

    <style name="HomeIconActionButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/home_action_button_height</item>
        <item name="backgroundTint">@color/home_card_bg</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="iconSize">@dimen/home_action_icon_size</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="iconPadding">0dp</item>
    </style>

    <style name="HomeActionLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/home_text_muted</item>
        <item name="android:textSize">10sp</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:gravity">center</item>
        <item name="android:maxLines">2</item>
    </style>
</resources>
