<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="2dp"
    android:orientation="vertical"
    android:padding="12dp"
    tools:background="@color/conv_message_stripe_a">

    <TextView
        android:id="@+id/textMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/app_text_label"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:text="Alice · 2024-01-01 12:00" />

    <TextView
        android:id="@+id/textBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/app_text_primary"
        android:textIsSelectable="true"
        android:textSize="14sp"
        tools:text="Message body…" />
</LinearLayout>
