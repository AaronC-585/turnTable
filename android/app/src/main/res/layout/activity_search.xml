<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg_main">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/app_bg_toolbar"
        app:navigationIconTint="@color/app_icon_emphasis"
        app:title="@string/search_pane_title"
        app:titleTextColor="@color/app_text_primary" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/searchTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:background="@color/app_bg_toolbar"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/home_token_label"
        app:tabMode="fixed"
        app:tabSelectedTextColor="@color/app_text_primary"
        app:tabTextColor="@color/app_text_tertiary" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:id="@+id/panelSearchMain"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/scanned_code"
                    app:hintTextColor="@color/app_text_label"
                    style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editBarcode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/app_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/secondarySearchTermsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/secondary_search_terms_hint"
                    app:hintTextColor="@color/app_text_label"
                    style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="24dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editSecondarySearchTerms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/app_text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/submit_search"
                    android:textColor="@color/app_text_on_button"
                    app:backgroundTint="@color/app_accent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonRedactedSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/redacted_search_in_app"
                    android:textColor="@color/app_text_on_button"
                    android:visibility="gone"
                    app:backgroundTint="@color/app_accent_purple" />
            </LinearLayout>
        </ScrollView>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/panelCollageSearch"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/app_card_browse"
                    app:strokeColor="@color/app_stroke_browse_card"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingBottom="8dp"
                            android:text="@string/redacted_collages_search_title"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingBottom="16dp"
                            android:text="@string/search_collage_pane_summary"
                            android:textColor="@color/app_text_tertiary"
                            android:textSize="14sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonOpenCollageSearch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_search_collages_in_app"
                            android:textColor="@color/app_text_on_button"
                            app:backgroundTint="@color/app_accent_purple" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </FrameLayout>
</LinearLayout>
