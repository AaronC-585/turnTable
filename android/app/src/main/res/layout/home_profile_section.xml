<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/home_card_bg"
    app:cardCornerRadius="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/app_button_secondary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textSectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/home_section_header_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:textColor="@color/home_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Statistics" />

        <LinearLayout
            android:id="@+id/layoutSectionRows"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
