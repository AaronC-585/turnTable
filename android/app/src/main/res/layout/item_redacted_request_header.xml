<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/app_bg_toolbar"
    android:orientation="horizontal"
    android:paddingHorizontal="8dp"
    android:paddingVertical="8dp">

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:paddingEnd="12dp"
                android:text="@string/redacted_requests_col_request"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="88dp"
                android:layout_height="wrap_content"
                android:paddingEnd="12dp"
                android:text="@string/redacted_requests_col_votes"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="88dp"
                android:layout_height="wrap_content"
                android:paddingEnd="12dp"
                android:text="@string/redacted_requests_col_bounty"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:paddingEnd="12dp"
                android:text="@string/redacted_requests_col_filled"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:paddingEnd="12dp"
                android:text="@string/redacted_requests_col_filled_by"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="96dp"
                android:layout_height="wrap_content"
                android:paddingEnd="12dp"
                android:text="@string/redacted_requests_col_requested_by"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:paddingEnd="12dp"
                android:text="@string/redacted_requests_col_created"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/redacted_requests_col_last_vote"
                android:textColor="@color/app_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>
</LinearLayout>
