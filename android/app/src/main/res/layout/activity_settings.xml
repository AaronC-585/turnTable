<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg_main">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/app_bg_toolbar"
        app:navigationIconTint="@color/app_icon_emphasis"
        app:title="@string/settings"
        app:titleTextColor="@color/app_toolbar_title" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/checkBeepOnScan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/beep_on_scan"
            android:textColor="@color/app_text_secondary"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/checkDownloadWifiOnly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pref_download_wifi_only"
            android:textColor="@color/app_text_secondary"
            android:layout_marginBottom="12dp" />

        <include
            android:id="@+id/expandTheme"
            layout="@layout/expandable_bullet_choice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/primary_search"
            android:textColor="@color/app_text_label"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonEditPrimaryList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/edit_primary_list"
            android:gravity="center_vertical|start"
            android:drawableStart="@drawable/ic_edit_pencil"
            android:drawableTint="@color/app_text_on_button"
            android:drawablePadding="8dp"
            android:padding="10dp"
            android:textColor="@color/app_text_on_button"
            app:backgroundTint="@color/app_accent"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textRedactedApiKeyHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/redacted_api_key_help"
            android:textColor="@color/app_text_help_small"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/redacted_api_key_hint"
            app:hintTextColor="@color/app_text_hint"
            style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
            app:endIconMode="password_toggle"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editRedactedApiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/app_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/redacted_torrent_download_dir_title"
            android:textColor="@color/app_text_label"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/textTorrentDownloadDirHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/redacted_torrent_download_dir_help"
            android:textColor="@color/app_text_help_small"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textTorrentDirSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/app_text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"
            tools:text="@string/redacted_torrent_download_dir_summary_default" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPickTorrentDir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/redacted_torrent_download_dir_pick"
                android:textColor="@color/app_text_on_button"
                app:backgroundTint="@color/app_accent"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonClearTorrentDir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/redacted_torrent_download_dir_clear"
                android:textColor="@color/app_text_primary"
                style="@style/Widget.MaterialComponents.Button.TextButton" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/torrent_clients_settings_title"
            android:textColor="@color/app_text_label"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/torrent_clients_inline_hint"
            android:textColor="@color/app_text_help_small"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textTorrentClientsSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/app_text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="8dp"
            tools:text="@string/torrent_clients_line_qbt_off" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonTorrentClientsSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/torrent_clients_settings_button"
            android:gravity="center_vertical|start"
            android:drawableStart="@drawable/ic_settings_gear"
            android:drawableTint="@color/app_text_on_button"
            android:drawablePadding="8dp"
            android:padding="10dp"
            android:textColor="@color/app_text_on_button"
            app:backgroundTint="@color/app_accent"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/textTheAudioDbHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/theaudiodb_api_key_help"
            android:textColor="@color/app_text_help_small"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/theaudiodb_api_key_hint"
            app:hintTextColor="@color/app_text_hint"
            style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editTheAudioDbApiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/app_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <include
            android:id="@+id/expandSecondaryPreset"
            layout="@layout/expandable_bullet_choice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonEditSecondaryList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/edit_secondary_list"
            android:gravity="center_vertical|start"
            android:drawableStart="@drawable/ic_edit_pencil"
            android:drawableTint="@color/app_text_on_button"
            android:drawablePadding="8dp"
            android:padding="10dp"
            android:textColor="@color/app_text_on_button"
            app:backgroundTint="@color/app_accent"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/secondary_search_hint"
            app:hintTextColor="@color/app_text_hint"
            style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editSecondaryUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top|start"
                android:inputType="textMultiLine|textUri|textNoSuggestions"
                android:minLines="4"
                android:scrollbars="vertical"
                android:typeface="monospace"
                android:textColor="@color/app_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <include
            android:id="@+id/expandSecondaryBrowser"
            layout="@layout/expandable_bullet_choice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/checkSecondaryAutoMusicBrainz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/secondary_auto_musicbrainz"
            android:textColor="@color/app_text_secondary"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_about"
            android:textColor="@color/app_text_hint"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAbout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_about"
            android:textColor="@color/app_text_on_button"
            app:backgroundTint="@color/app_button_neutral"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCheckUpdates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/github_update_check_button"
            android:textColor="@color/app_text_on_button"
            app:backgroundTint="@color/app_accent_green_dark"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonDonate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_donate"
            android:textColor="@color/app_text_on_button"
            app:backgroundTint="@color/app_paypal"
            android:layout_marginBottom="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonSave"
            style="@style/Widget.Redacted.Button.Save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save" />
    </LinearLayout>
    </ScrollView>
</LinearLayout>
