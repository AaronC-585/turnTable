<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg_main">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/app_surface_input"
        app:title="@string/redacted_top10"
        app:titleTextColor="@color/app_text_primary"
        app:navigationIconTint="@color/app_icon_emphasis" />

    <ListView
        android:id="@+id/listType"
        android:layout_width="match_parent"
        android:layout_height="132dp"
        android:layout_margin="8dp"
        android:background="@drawable/redacted_listbox_background"
        android:choiceMode="singleChoice"
        android:divider="@color/app_stroke_browse_card"
        android:dividerHeight="1dp"
        android:paddingVertical="4dp"
        android:scrollbars="vertical" />

    <ListView
        android:id="@+id/listLimit"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginHorizontal="8dp"
        android:background="@drawable/redacted_listbox_background"
        android:choiceMode="singleChoice"
        android:divider="@color/app_stroke_browse_card"
        android:dividerHeight="1dp"
        android:paddingVertical="4dp"
        android:scrollbars="vertical" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonLoad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:text="@string/redacted_load"
        app:backgroundTint="@color/app_accent" />

    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
