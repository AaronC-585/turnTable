<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg_main"
    tools:context=".HomeActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/app_bg_toolbar">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIconTint="@color/app_icon_emphasis"
            app:titleTextColor="@color/app_toolbar_title" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/loadingTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:importantForAccessibility="no"
            android:indeterminate="true"
            app:indicatorColor="@color/home_ratio_ok"
            app:trackColor="@color/app_progress_track"
            app:trackThickness="3dp" />
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/layoutNoKey"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/textNoApiKeyHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/home_no_api_key_hint"
                android:textColor="@color/app_text_tertiary"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAddApiKey"
                style="@style/Widget.Redacted.Button.Add"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/home_enter_api_key" />
        </LinearLayout>

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/scrollProfile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true"
                android:overScrollMode="ifContentScrolls">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="24dp">

                    <!-- Shown on other users' profiles only: same home action as former toolbar item. -->
                    <LinearLayout
                        android:id="@+id/rowProfileHomeAction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:paddingTop="4dp"
                        android:visibility="gone">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonProfileNavigateHome"
                            style="@style/HomeIconActionButton"
                            android:contentDescription="@string/nav_home"
                            app:icon="@drawable/ic_home" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <!-- Narrow column: avatar + Personal stats -->
                        <LinearLayout
                            android:layout_width="@dimen/home_profile_column_width"
                            android:layout_height="wrap_content"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <ImageView
                                android:id="@+id/imageProfile"
                                android:layout_width="@dimen/home_profile_icon_size"
                                android:layout_height="@dimen/home_profile_icon_size"
                                android:contentDescription="@string/home_profile_image_description"
                                android:scaleType="centerCrop"
                                android:background="@color/app_progress_track" />

                            <FrameLayout
                                android:id="@+id/containerHeaderPersonal"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:minHeight="0dp" />
                        </LinearLayout>

                        <!-- Username + Statistics (wider) -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <FrameLayout
                                android:id="@+id/containerHeaderStatistics"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="0dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Subscriptions, mail, friends: on profile tab only (not in bottom dock). -->
                    <LinearLayout
                        android:id="@+id/rowHomeProfileSocialActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="8dp">

                        <LinearLayout
                            android:id="@+id/homeProfileActionSubscriptions"
                            style="@style/HomeActionColumn"
                            android:contentDescription="@string/home_content_cd_subscriptions">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonHomeProfileSubscriptions"
                                style="@style/HomeIconActionButton"
                                app:icon="@android:drawable/ic_menu_agenda" />

                            <TextView
                                style="@style/HomeActionLabel"
                                android:text="@string/nav_subscriptions" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/homeProfileActionMail"
                            style="@style/HomeActionColumn"
                            android:contentDescription="@string/home_content_cd_mail">

                            <FrameLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/buttonHomeProfileMail"
                                    style="@style/HomeIconActionButton"
                                    app:icon="@drawable/ic_mail" />

                                <TextView
                                    android:id="@+id/badgeMailUnreadHome"
                                    android:layout_width="wrap_content"
                                    android:layout_height="18dp"
                                    android:minWidth="18dp"
                                    android:layout_gravity="top|end"
                                    android:layout_marginTop="0dp"
                                    android:layout_marginEnd="0dp"
                                    android:background="@drawable/bg_mail_unread_badge"
                                    android:clickable="false"
                                    android:focusable="false"
                                    android:gravity="center"
                                    android:includeFontPadding="false"
                                    android:paddingHorizontal="5dp"
                                    android:textColor="@color/app_text_on_button"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:visibility="gone"
                                    tools:text="3"
                                    tools:visibility="visible" />
                            </FrameLayout>

                            <TextView
                                style="@style/HomeActionLabel"
                                android:text="@string/nav_mail" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/homeProfileActionFriends"
                            style="@style/HomeActionColumn"
                            android:contentDescription="@string/home_content_cd_friends">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonHomeProfileFriends"
                                style="@style/HomeIconActionButton"
                                app:icon="@drawable/ic_people_friends" />

                            <TextView
                                style="@style/HomeActionLabel"
                                android:text="@string/nav_friends" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/containerProfileSections"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <TextView
            android:id="@+id/textError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="24dp"
            android:textColor="@color/app_error"
            android:textSize="15sp"
            android:visibility="gone" />
    </FrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
