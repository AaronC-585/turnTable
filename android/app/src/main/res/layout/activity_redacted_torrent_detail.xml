<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg_main">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/app_surface_input">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@color/app_text_primary"
            app:navigationIconTint="@color/app_icon_emphasis" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/app_card_browse"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/app_chip_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerSectionRelease"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/redacted_section_release"
                            android:textColor="@color/app_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chevronRelease"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_section_chevron"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/contentSectionRelease"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:id="@+id/textReleaseTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/app_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textReleaseArtists"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="14sp"
                            android:visibility="gone" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonOpenAlbumInApp"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/redacted_torrent_open_album"
                            android:textColor="@color/app_accent"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/app_card_browse"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/app_chip_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerSectionTorrent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/redacted_section_this_torrent"
                            android:textColor="@color/app_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chevronTorrent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_section_chevron"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/contentSectionTorrent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/imageTorrentSeedingAcorn"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginEnd="8dp"
                                android:contentDescription="@string/redacted_seeding_indicator_desc"
                                android:visibility="gone"
                                app:srcCompat="@drawable/ic_acorn_seeding" />

                            <TextView
                                android:id="@+id/textTorrentFormatLine"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="@color/app_text_primary"
                                android:textSize="15sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/textTorrentStats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/textTorrentUploader"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="13sp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/textTorrentTechnical"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="monospace"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="11sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sectionTorrentDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/app_card_browse"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/app_chip_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerSectionTorrentDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/redacted_release_description"
                            android:textColor="@color/app_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chevronTorrentDescription"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_section_chevron"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/contentSectionTorrentDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:id="@+id/textTorrentDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/app_text_secondary"
                            android:textIsSelectable="true"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sectionTorrentFiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/app_card_browse"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/app_chip_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerSectionTorrentFiles"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/redacted_file_list_title"
                            android:textColor="@color/app_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chevronTorrentFiles"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_section_chevron"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/contentSectionTorrentFiles"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="12dp">

                        <TextView
                            android:id="@+id/textTorrentFileList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:textColor="@color/app_text_secondary"
                            android:textIsSelectable="true"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/app_card_browse"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/app_chip_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/headerSectionTorrentActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/redacted_section_site_tools"
                            android:textColor="@color/app_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/chevronTorrentActions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_section_chevron"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/contentSectionTorrentActions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTorrentDownload"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_download"
                            app:backgroundTint="@color/app_accent" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTorrentDownloadToken"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_use_token"
                            android:visibility="gone"
                            app:backgroundTint="@color/app_button_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTorrentQbt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_send_qbittorrent"
                            android:visibility="gone"
                            app:backgroundTint="@color/app_button_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTorrentQbtToken"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_send_qbittorrent_with_token"
                            android:visibility="gone"
                            app:backgroundTint="@color/app_button_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTorrentTransmission"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_send_transmission"
                            android:visibility="gone"
                            app:backgroundTint="@color/app_button_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTorrentTransmissionToken"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_send_transmission_with_token"
                            android:visibility="gone"
                            app:backgroundTint="@color/app_button_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTorrentRtorrent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_send_rtorrent"
                            android:visibility="gone"
                            app:backgroundTint="@color/app_button_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTorrentRtorrentToken"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_send_rtorrent_with_token"
                            android:visibility="gone"
                            app:backgroundTint="@color/app_button_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTorrentDeluge"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_send_deluge"
                            android:visibility="gone"
                            app:backgroundTint="@color/app_button_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTorrentDelugeToken"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_send_deluge_with_token"
                            android:visibility="gone"
                            app:backgroundTint="@color/app_button_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTorrentEdit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_edit_torrent_short"
                            app:backgroundTint="@color/app_chip_stroke" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTorrentOpenSite"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_open_on_site"
                            app:backgroundTint="@color/app_button_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTorrentCopyPermalink"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_permalink"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:textColor="@color/app_accent" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/textTorrentError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressTorrentDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
