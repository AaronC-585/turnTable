<?xml version="1.0" encoding="utf-8"?>
<!-- Docked at bottom of most screens: tracker status + shortcut row. Inflated by [AppBottomBars]. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/appBottomDock"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/app_bg_bottom_nav"
    android:elevation="6dp">

    <LinearLayout
        android:id="@+id/trackerStatusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/app_bg_bottom_nav"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="4dp"
        android:paddingHorizontal="4dp">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/imageTrackerWebsite"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/tracker_status_service_website"
                android:src="@drawable/tracker_status_website"
                android:tint="@color/tracker_status_down" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/imageTrackerHttp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/tracker_status_service_http"
                android:src="@drawable/tracker_status_http"
                android:tint="@color/tracker_status_down" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/imageTrackerHttps"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/tracker_status_service_https"
                android:src="@drawable/tracker_status_https"
                android:tint="@color/tracker_status_down" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/imageTrackerIrc"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/tracker_status_service_irc"
                android:src="@drawable/tracker_status_irc"
                android:tint="@color/tracker_status_down" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/imageTrackerAnnouncer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/tracker_status_service_announcer"
                android:src="@drawable/tracker_status_announcer"
                android:tint="@color/tracker_status_down" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1">

            <ImageView
                android:id="@+id/imageTrackerUserId"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:adjustViewBounds="true"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:contentDescription="@string/tracker_status_service_user_id"
                android:src="@drawable/tracker_status_userid"
                android:tint="@color/tracker_status_down" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutHomeActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="4dp"
        android:background="@color/app_bg_bottom_nav"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <LinearLayout
            android:id="@+id/homeActionNews"
            style="@style/HomeActionColumn"
            android:contentDescription="@string/home_content_cd_news">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonHomeNews"
                style="@style/HomeIconActionButton"
                app:icon="@drawable/ic_newspaper" />

            <TextView
                style="@style/HomeActionLabel"
                android:text="@string/nav_news" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeActionMail"
            style="@style/HomeActionColumn"
            android:contentDescription="@string/home_content_cd_mail">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonHomeMail"
                    style="@style/HomeIconActionButton"
                    app:icon="@drawable/ic_mail" />

                <TextView
                    android:id="@+id/badgeMailUnread"
                    android:layout_width="wrap_content"
                    android:layout_height="18dp"
                    android:minWidth="18dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="0dp"
                    android:layout_marginEnd="0dp"
                    android:background="@drawable/bg_mail_unread_badge"
                    android:clickable="false"
                    android:focusable="false"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:paddingHorizontal="5dp"
                    android:textColor="@color/app_text_on_button"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="3"
                    tools:visibility="visible" />
            </FrameLayout>

            <TextView
                style="@style/HomeActionLabel"
                android:text="@string/nav_mail" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeActionHome"
            style="@style/HomeActionColumn"
            android:contentDescription="@string/home_content_cd_profile">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonHomeHome"
                style="@style/HomeIconActionButton"
                app:icon="@drawable/ic_home" />

            <TextView
                style="@style/HomeActionLabel"
                android:text="@string/nav_profile" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeActionFriends"
            style="@style/HomeActionColumn"
            android:contentDescription="@string/home_content_cd_friends">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonHomeFriends"
                style="@style/HomeIconActionButton"
                app:icon="@drawable/ic_people_friends" />

            <TextView
                style="@style/HomeActionLabel"
                android:text="@string/nav_friends" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeActionScan"
            style="@style/HomeActionColumn"
            android:contentDescription="@string/home_content_cd_scan">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonHomeScan"
                style="@style/HomeIconActionButton"
                app:icon="@android:drawable/ic_menu_camera" />

            <TextView
                style="@style/HomeActionLabel"
                android:text="@string/scan" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeActionHistory"
            style="@style/HomeActionColumn"
            android:contentDescription="@string/home_content_cd_history">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonHomeHistory"
                style="@style/HomeIconActionButton"
                app:icon="@android:drawable/ic_menu_recent_history" />

            <TextView
                style="@style/HomeActionLabel"
                android:text="@string/history" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeActionSettings"
            style="@style/HomeActionColumn"
            android:contentDescription="@string/home_content_cd_settings">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonHomeSettings"
                style="@style/HomeIconActionButton"
                app:icon="@drawable/ic_settings_gear" />

            <TextView
                style="@style/HomeActionLabel"
                android:text="@string/settings" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/homeActionRedacted"
            style="@style/HomeActionColumn"
            android:contentDescription="@string/home_content_cd_redacted">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonHomeRedacted"
                style="@style/HomeIconActionButton"
                app:icon="@android:drawable/ic_menu_compass" />

            <TextView
                style="@style/HomeActionLabel"
                android:text="@string/redacted_torrent_search" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
