<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:minHeight="48dp"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.4"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imageSeedingUtorrent"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginEnd="6dp"
            android:contentDescription="@string/redacted_seeding_indicator_desc"
            android:importantForAccessibility="no"
            android:scaleType="fitCenter"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_utorrent_seed"
            app:tint="@null" />
        <!-- Vector sets its own stroke color; @null tint keeps drawable colors -->

        <TextView
            android:id="@+id/textFormat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/app_text_primary"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textSize"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.1"
        android:gravity="end"
        android:textColor="@color/app_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/textSnatched"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.75"
        android:gravity="end"
        android:textColor="@color/app_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/textSeeders"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.65"
        android:gravity="end"
        android:textColor="@color/app_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/textLeechers"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.65"
        android:gravity="end"
        android:textColor="@color/app_text_secondary"
        android:textSize="13sp" />
</LinearLayout>
