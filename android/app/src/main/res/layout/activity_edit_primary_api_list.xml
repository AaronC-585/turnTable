<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#eeeeee"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/textHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#aaaaaa"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/secondary_edit_dropdown_label"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerPrimaryEntries"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@android:drawable/btn_dropdown"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/checkPrimaryEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/primary_edit_enabled"
            android:textColor="#cccccc"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/secondary_edit_name_hint"
            app:boxBackgroundColor="#2a2a2a"
            app:hintTextColor="#888888"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="#3a7bd5"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editDisplayName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="#eeeeee" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/primary_edit_cmd_hint"
            app:boxBackgroundColor="#2a2a2a"
            app:hintTextColor="#888888"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="#3a7bd5"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editSearchCmd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine|textNoSuggestions"
                android:minLines="6"
                android:typeface="monospace"
                android:textColor="#eeeeee" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/primary_edit_add_from_dropdown"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinnerPrimaryApiTypes"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@android:drawable/btn_dropdown"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="18dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginBottom="18dp">

            <Button
                android:id="@+id/buttonMoveUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/secondary_edit_move_up"
                android:textColor="#ffffff"
                app:backgroundTint="#555555"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/buttonMoveDown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/secondary_edit_move_down"
                android:textColor="#ffffff"
                app:backgroundTint="#555555"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/buttonRemove"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/secondary_edit_remove"
                android:textColor="#ffffff"
                app:backgroundTint="#b71c1c"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/buttonAdd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/secondary_edit_add"
                android:textColor="#ffffff"
                app:backgroundTint="#3a7bd5" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <Button
                android:id="@+id/buttonCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cancel"
                android:textColor="#ffffff"
                app:backgroundTint="#444444"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/buttonSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_list_save"
                android:textColor="#ffffff"
                app:backgroundTint="#3a7bd5" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
