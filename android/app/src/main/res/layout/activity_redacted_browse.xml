<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg_root_browse">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/app_bg_toolbar"
        app:title="@string/redacted_browse_header"
        app:titleTextColor="@color/app_text_primary"
        app:navigationIconTint="@color/app_icon_emphasis" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/app_card_browse"
                app:strokeColor="@color/app_stroke_browse_card"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/redacted_browse_filter_title"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:paddingBottom="8dp" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleSearchMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        app:singleSelection="true"
                        app:checkedButton="@+id/btnModeAdvanced">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnModeBasic"
                            style="@style/Widget.Redacted.Button.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_browse_mode_basic"
                            android:textColor="@color/app_chip_text"
                            app:strokeColor="@color/app_chip_stroke" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnModeAdvanced"
                            style="@style/Widget.Redacted.Button.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_browse_mode_advanced"
                            android:textColor="@color/app_chip_text"
                            app:strokeColor="@color/app_chip_stroke" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <LinearLayout
                        android:id="@+id/panelBasic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/redacted_browse_search_terms"
                            app:hintTextColor="@color/app_text_label"
                            style="@style/Widget.Redacted.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editSearchStr"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:textColor="@color/app_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/panelAdvanced"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/redacted_browse_artist_name"
                            app:hintTextColor="@color/app_text_label"
                            style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
                            android:layout_marginBottom="6dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editArtistName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:textColor="@color/app_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/redacted_browse_album_torrent_name"
                            app:hintTextColor="@color/app_text_label"
                            style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
                            android:layout_marginBottom="6dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editGroupName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:textColor="@color/app_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/redacted_browse_record_label"
                            app:hintTextColor="@color/app_text_label"
                            style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
                            android:layout_marginBottom="6dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editRecordLabel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:textColor="@color/app_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="@string/redacted_browse_catalogue_number"
                                app:hintTextColor="@color/app_text_label"
                                style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
                                android:layout_marginEnd="6dp"
                                android:layout_marginBottom="6dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/editCatalogueNumber"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text"
                                    android:textColor="@color/app_text_primary" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:hint="@string/redacted_browse_year"
                                app:hintTextColor="@color/app_text_label"
                                style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
                                android:layout_marginBottom="6dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/editYear"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="number"
                                    android:textColor="@color/app_text_primary" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="@string/redacted_browse_edition_title"
                                app:hintTextColor="@color/app_text_label"
                                style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
                                android:layout_marginEnd="6dp"
                                android:layout_marginBottom="6dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/editRemasterTitle"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="text"
                                    android:textColor="@color/app_text_primary" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                android:hint="@string/redacted_browse_edition_year"
                                app:hintTextColor="@color/app_text_label"
                                style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
                                android:layout_marginBottom="6dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/editRemasterYear"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="number"
                                    android:textColor="@color/app_text_primary" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/redacted_browse_file_list"
                            app:hintTextColor="@color/app_text_label"
                            style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
                            android:layout_marginBottom="6dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editFileList"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:textColor="@color/app_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/redacted_browse_torrent_description"
                            app:hintTextColor="@color/app_text_label"
                            style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
                            android:layout_marginBottom="8dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editTorrentDescription"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:textColor="@color/app_text_primary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_browse_rip_specifics"
                            android:textColor="@color/app_text_muted"
                            android:textSize="12sp"
                            android:paddingBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:orientation="vertical">

                            <include
                                android:id="@+id/expandEncoding"
                                layout="@layout/expandable_bullet_choice" />

                            <include
                                android:id="@+id/expandFormat"
                                layout="@layout/expandable_bullet_choice" />

                            <include
                                android:id="@+id/expandMedia"
                                layout="@layout/expandable_bullet_choice" />

                            <include
                                android:id="@+id/expandReleaseType"
                                layout="@layout/expandable_bullet_choice" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_browse_misc"
                            android:textColor="@color/app_text_muted"
                            android:textSize="12sp"
                            android:paddingBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:orientation="vertical">

                            <include
                                android:id="@+id/expandHasLog"
                                layout="@layout/expandable_bullet_choice" />

                            <HorizontalScrollView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:scrollbars="none"
                                android:layout_marginBottom="8dp">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="6dp"
                                        android:background="@drawable/redacted_listbox_background"
                                        android:orientation="vertical"
                                        android:paddingHorizontal="6dp"
                                        android:paddingVertical="4dp">

                                        <com.google.android.material.switchmaterial.SwitchMaterial
                                            android:id="@+id/switchHasCue"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:minWidth="140dp"
                                            android:text="@string/redacted_browse_col_hascue"
                                            android:textColor="@color/app_text_secondary"
                                            android:textSize="12sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="6dp"
                                        android:background="@drawable/redacted_listbox_background"
                                        android:orientation="vertical"
                                        android:paddingHorizontal="6dp"
                                        android:paddingVertical="4dp">

                                        <com.google.android.material.switchmaterial.SwitchMaterial
                                            android:id="@+id/switchScene"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:minWidth="140dp"
                                            android:text="@string/redacted_browse_col_scene"
                                            android:textColor="@color/app_text_secondary"
                                            android:textSize="12sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="6dp"
                                        android:background="@drawable/redacted_listbox_background"
                                        android:orientation="vertical"
                                        android:paddingHorizontal="6dp"
                                        android:paddingVertical="4dp">

                                        <com.google.android.material.switchmaterial.SwitchMaterial
                                            android:id="@+id/switchVanityHouse"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:minWidth="140dp"
                                            android:text="@string/redacted_browse_col_vanity"
                                            android:textColor="@color/app_text_secondary"
                                            android:textSize="12sp" />
                                    </LinearLayout>
                                </LinearLayout>
                            </HorizontalScrollView>

                            <include
                                android:id="@+id/expandFreeTorrent"
                                layout="@layout/expandable_bullet_choice" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/redacted_browse_tags_hint"
                        app:hintTextColor="@color/app_text_label"
                        style="@style/Widget.Redacted.TextInputLayout.OutlinedBox"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="6dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editTaglist"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:textColor="@color/app_text_primary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <RadioGroup
                        android:id="@+id/radioTagsMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <RadioButton
                            android:id="@+id/radioTagsAny"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/redacted_browse_tags_any"
                            android:textColor="@color/app_text_secondary"
                            android:checked="true"
                            android:buttonTint="@color/app_accent" />

                        <RadioButton
                            android:id="@+id/radioTagsAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="@string/redacted_browse_tags_all"
                            android:textColor="@color/app_text_secondary"
                            android:buttonTint="@color/app_accent" />
                    </RadioGroup>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal">

                        <include
                            android:id="@+id/expandOrderBy"
                            layout="@layout/expandable_bullet_choice"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1" />

                        <include
                            android:id="@+id/expandOrderWay"
                            layout="@layout/expandable_bullet_choice"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchGroupResults"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/redacted_browse_group_by_release"
                        android:textColor="@color/app_text_secondary"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/redacted_browse_categories"
                        android:textColor="@color/app_text_muted"
                        android:textSize="12sp"
                        android:paddingBottom="4dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:layout_marginBottom="8dp">

                        <CheckBox
                            android:id="@+id/checkCat1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/redacted_browse_cat_music"
                            android:textColor="@color/app_text_secondary" />
                        <CheckBox
                            android:id="@+id/checkCat2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/redacted_browse_cat_apps"
                            android:textColor="@color/app_text_secondary" />
                        <CheckBox
                            android:id="@+id/checkCat3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/redacted_browse_cat_ebooks"
                            android:textColor="@color/app_text_secondary" />
                        <CheckBox
                            android:id="@+id/checkCat4"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/redacted_browse_cat_audiobooks"
                            android:textColor="@color/app_text_secondary" />
                        <CheckBox
                            android:id="@+id/checkCat5"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/redacted_browse_cat_elearning"
                            android:textColor="@color/app_text_secondary" />
                        <CheckBox
                            android:id="@+id/checkCat6"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/redacted_browse_cat_comedy"
                            android:textColor="@color/app_text_secondary" />
                        <CheckBox
                            android:id="@+id/checkCat7"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:text="@string/redacted_browse_cat_comics"
                            android:textColor="@color/app_text_secondary" />
                    </GridLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonReset"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/redacted_browse_reset"
                            app:backgroundTint="@color/app_button_secondary"
                            android:layout_marginEnd="6dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonSearch"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/redacted_browse_filter_torrents"
                            app:backgroundTint="@color/app_accent" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
