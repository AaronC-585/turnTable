<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a1a"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_onboarding_title"
            android:textColor="#eeeeee"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_onboarding_intro"
            android:textColor="#aaaaaa"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Internet -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_internet_title"
            android:textColor="#eeeeee"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_internet_why"
            android:textColor="#aaaaaa"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />
        <TextView
            android:id="@+id/textInternetStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_internet_status"
            android:textColor="#88cc88"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- Camera -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_camera_title"
            android:textColor="#eeeeee"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_camera_why"
            android:textColor="#aaaaaa"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />
        <Button
            android:id="@+id/buttonRequestCamera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/permission_request_camera"
            android:textColor="#ffffff"
            app:backgroundTint="#3a7bd5"
            android:layout_marginBottom="8dp" />
        <TextView
            android:id="@+id/textCameraStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#88cc88"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/buttonContinue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_continue"
            android:textColor="#ffffff"
            app:backgroundTint="#3a7bd5" />
    </LinearLayout>
</ScrollView>
