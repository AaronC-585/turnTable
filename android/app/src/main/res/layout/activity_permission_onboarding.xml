<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg_main">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/app_bg_toolbar"
        app:title="@string/permission_onboarding_title"
        app:titleTextColor="@color/app_text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_onboarding_intro"
            android:textColor="@color/app_text_help"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Internet -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_internet_title"
            android:textColor="@color/app_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_internet_why"
            android:textColor="@color/app_text_help"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />
        <TextView
            android:id="@+id/textInternetStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_internet_status"
            android:textColor="@color/app_permission_ok"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- Camera -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_camera_title"
            android:textColor="@color/app_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_camera_why"
            android:textColor="@color/app_text_help"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRequestCamera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/permission_request_camera"
            android:textColor="@color/app_text_on_button"
            app:backgroundTint="@color/app_accent"
            android:layout_marginBottom="8dp" />
        <TextView
            android:id="@+id/textCameraStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/app_permission_ok"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonContinue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/permission_continue"
            android:textColor="@color/app_text_on_button"
            app:backgroundTint="@color/app_accent" />
    </LinearLayout>
    </ScrollView>
</LinearLayout>
