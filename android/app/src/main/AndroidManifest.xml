        <activity android:name=".RedactedCollageActivity" android:exported="false" android:theme="@style/Theme.BarcodeScanner" />
        <activity android:name=".RedactedTorrentDetailActivity" android:exported="false" android:theme="@style/Theme.BarcodeScanner" />
        <activity android:name=".RedactedSimilarArtistsActivity" android:exported="false" android:theme="@style/Theme.BarcodeScanner" />
        <activity android:name=".RedactedRequestDetailActivity" android:exported="false" android:theme="@style/Theme.BarcodeScanner" />
    </application>

</manifest>
