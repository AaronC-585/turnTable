<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Android 11+: resolve the system installer for ACTION_VIEW on downloaded APKs -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="application/vnd.android.package-archive" />
        </intent>
    </queries>

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Lets the app open the system installer for downloaded APKs (update flow). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-feature android:name="android.hardware.camera" android:required="true" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    <!-- Limit to phone and tablet only (exclude TV, watch, auto) -->
    <uses-feature android:name="android.hardware.touchscreen" android:required="true" />
    <uses-feature android:name="android.software.leanback" android:required="false" />

    <!-- largeHeap: use the device's "large" Dalvik/ART heap limit (ActivityManager.getLargeMemoryClass).
         OEM-defined; often ~2× default heap — Android has no public API for an exact 4× multiplier. -->
    <application
        android:name=".TurnTableApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BarcodeScanner">

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.BarcodeScanner">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- Deep links + share-to-app for redacted.sh -->
        <activity
            android:name=".RedactedLinkDispatchActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:scheme="https" android:host="redacted.sh" />
                <data android:scheme="http" android:host="redacted.sh" />
                <data android:scheme="https" android:host="www.redacted.sh" />
                <data android:scheme="http" android:host="www.redacted.sh" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>
        <activity
            android:name=".HomeActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/Theme.BarcodeScanner" />
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize"
            android:theme="@style/Theme.BarcodeScanner" />
        <activity
            android:name=".SearchActivity"
            android:exported="false"
            android:theme="@style/Theme.BarcodeScanner" />
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.BarcodeScanner" />
        <activity
            android:name=".AboutActivity"
            android:exported="false"
            android:theme="@style/Theme.BarcodeScanner" />
        <activity
            android:name=".PermissionOnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.BarcodeScanner" />
        <activity
            android:name=".EditSearchListActivity"
            android:exported="false"
            android:theme="@style/Theme.BarcodeScanner" />
        <activity
            android:name=".EditPrimaryApiListActivity"
            android:exported="false"
            android:theme="@style/Theme.BarcodeScanner" />
        <activity
            android:name=".EditSecondaryListActivity"
            android:exported="false"
            android:theme="@style/Theme.BarcodeScanner" />
        <activity
            android:name=".TorrentClientsSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.BarcodeScanner" />
        <activity
            android:name=".SearchHistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.BarcodeScanner" />
        <activity
            android:name=".DebugEventLogActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:theme="@style/Theme.BarcodeScanner" />
        <activity android:name=".RedactedBrowseActivity" android:exported="false" android:theme="@style/Theme.BarcodeScanner" />
        <activity android:name=".RedactedBrowseResultsActivity" android:exported="false" android:theme="@style/Theme.BarcodeScanner" />
        <activity android:name=".RedactedCollagesSearchActivity" android:exported="false" android:theme="@style/Theme.BarcodeScanner" />
        <activity android:name=".RedactedCollagesSearchResultsActivity" android:exported="false" android:theme="@style/Theme.BarcodeScanner" />
        <activity android:name=".RedactedTorrentGroupActivity" android:exported="false" android:theme="@style/Theme.BarcodeScanner" />
        <activity android:name=".RedactedAccountActivity" android:exported="false" android:theme="@style/Theme.BarcodeScanner" />
