{
  "name": "turntable",
  "private": true,
  "description": "turnTable — native scanner app; npm scripts wrap Gradle for CI and local builds",
  "scripts": {
    "build:android": "cd android && ./gradlew :app:assembleRelease :app:printAppVersion -PABI_FILTERS=arm64-v8a,x86_64 -Dorg.gradle.java.home=\"${JAVA_HOME}\"",
    "build:android:debug": "cd android && ./gradlew :app:assembleDebug -Dorg.gradle.java.home=\"${JAVA_HOME}\""
  }
}
